{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "node": "22.12.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AI_BASE_URL": "https://api.deepseek.com",
        "EXPO_PUBLIC_AI_MODEL": "deepseek-chat",
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8000"
      }
    },
    "production": {
      "node": "22.12.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_AI_BASE_URL": "https://api.deepseek.com",
        "EXPO_PUBLIC_AI_MODEL": "deepseek-chat"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

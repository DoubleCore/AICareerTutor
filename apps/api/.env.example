# App
APP_NAME=AI Career Tutor API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS: "*" for all, or comma-separated origins
# e.g. http://localhost:8081,http://localhost:19006
CORS_ORIGINS=*

# Supabase (wired in a later phase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI / LLM
# AI_MODE: mock(默认,零密钥零依赖,演示/CI 安全) | real(走真实 Claude 结构化输出)
# real 模式需填 AI_API_KEY;缺 key 或调用失败时会自动回退 mock,链路不中断。
# 真实密钥只写进本地 .env(已 gitignore),切勿提交。
AI_MODE=mock
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=
AI_MAX_TOKENS=2000

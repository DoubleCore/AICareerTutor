# App
APP_NAME=AI Career Tutor API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS: "*" for all, or comma-separated origins
# e.g. http://localhost:8081,http://localhost:19006
CORS_ORIGINS=*

# Supabase (wired in a later phase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI / LLM
# AI_MODE: mock(默认,零密钥零依赖,演示/CI 安全) | real(走真实模型结构化输出)
# real 模式需填 AI_API_KEY;缺 key 或调用失败时会自动回退 mock,链路不中断。
# 真实密钥只写进本地 .env(已 gitignore),切勿提交。
AI_MODE=mock

# AI_PROVIDER: real 模式下选哪家 SDK
#   anthropic = 官方 Claude(Anthropic SDK)
#   openai    = OpenAI 兼容端点(DeepSeek 等),需配 AI_BASE_URL
AI_PROVIDER=anthropic

# AI_BASE_URL: 仅 openai provider 用;留空走 openai 官方默认。
# DeepSeek 填 https://api.deepseek.com
AI_BASE_URL=

# AI_MODEL: 按 provider 选模型名
#   anthropic: claude-sonnet-4-6 等
#   openai/DeepSeek: deepseek-v4-pro 或 deepseek-v4-flash
AI_MODEL=claude-sonnet-4-6

AI_API_KEY=
AI_MAX_TOKENS=2000

# 示例:接 DeepSeek(OpenAI 兼容,允许服务端调用)——
#   AI_MODE=real
#   AI_PROVIDER=openai
#   AI_BASE_URL=https://api.deepseek.com
#   AI_MODEL=deepseek-v4-pro
#   AI_API_KEY=sk-xxxx   # 只写本地 .env,勿提交

# 文件上传 / MP3 语音转写
# MAX_UPLOAD_MB: /interview/transcribe 单文件大小上限(MB),超限拒绝。
MAX_UPLOAD_MB=25

# MP3 ASR(阿里云百炼 Paraformer)—— 本轮端点仅桩(返回 501),以下为将来接入预留。
# 真实接法见 spec: .spec-workflow/specs/backend-feature-optimization/mp3-asr-aliyun.md
# 密钥/凭证只写本地 .env(已 gitignore),切勿提交。
# DASHSCOPE_API_KEY=
# ASR_MODEL=paraformer-v2
# OSS_BUCKET=
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
